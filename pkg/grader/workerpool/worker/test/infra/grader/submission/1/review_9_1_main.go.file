package game

import (
	"fmt"
	"log/slog"
	"strings"
)

// my new file file

// Place
const (
	kitchenPlace = "кухня"
	hallPlace    = "коридор"
	roomPlace    = "комната"
	streetPlace  = "улица"
)

// Actions
const (
	lookAroundAction = "осмотреться"
	goToAction       = "идти"
	putOnAction      = "надеть"
	takeAction       = "взять"
	applyAction      = "применить"
)

// Inventory
const (
	bagInventory   = "рюкзак"
	keysInventory  = "ключи"
	notesInventory = "конспекты"
)

// Room(place) Object for Actions
const (
	doorObject = "дверь"
	// шкаф
)

type Hero struct {
	pos         *Place
	bag         map[string]struct{}
	inv         map[string]struct{}
	doneActions []Action
}

type Action struct {
	inv, obj string
	done     bool
	do       func() string
}

type Place struct {
	ID         int
	name       string
	inv        map[string]struct{}
	actions    []Action
	nextPlace  map[string]struct{}
	lookAround func() string
	getInfo    func() string
	checkEnter func() (string, error)
}

func (h *Hero) GoTo(pl []string) (string, error) {
	if len(pl) > 1 {
		return "", fmt.Errorf("too many params for goTo command: %s", pl)
	}

	if _, ok := h.pos.nextPlace[pl[0]]; !ok {
		return "нет пути в комната", fmt.Errorf("this place you can not go: %s", pl[0])
	}
	nextRoom := PlacePlan[pl[0]]

	if nextRoom.checkEnter != nil {
		res, err := nextRoom.checkEnter()
		if err != nil {
			return res, err
		}
	}

	h.pos = PlacePlan[pl[0]]

	return "", nil
}

func (h *Hero) Take(i []string) (string, error) {
	if h.pos.inv == nil {
		return "", fmt.Errorf("no inventory in room")
	}

	if len(i) == 0 {
		return "", fmt.Errorf("no item provided for take")
	}

	if h.bag == nil {
		return "некуда класть", fmt.Errorf("no bag in hero")
	}

	res := "предмет добавлен в инвентарь: "
	checkFlag := false
	for _, v := range i {
		if _, ok := h.pos.inv[v]; ok {
			h.bag[v] = struct{}{}
			delete(h.pos.inv, v)
			res += v + " "
			checkFlag = true
		}
	}
	if checkFlag {
		return strings.TrimSuffix(res, " "), nil
	}
	return "нет такого", nil
}

func (h *Hero) PutOn(i []string) (string, error) {
	// check inventory in the room
	if h.pos.inv == nil {
		return "", fmt.Errorf("no inventory in room")
	}

	if len(i) == 0 {
		return "", fmt.Errorf("no item provided for put on")
	}

	if i[0] != bagInventory {
		return "", fmt.Errorf("the item cannot be worn")
	}

	bag := i[0]

	if _, ok := h.pos.inv[bag]; !ok {
		return "", fmt.Errorf("no inventory in room %s", bag)
	}

	h.bag = make(map[string]struct{})
	delete(h.pos.inv, bag)
	return fmt.Sprintf("вы надели: %s", bag), nil
}

func (h *Hero) Apply(i []string) (string, error) {
	if len(i) != 2 {
		return "", fmt.Errorf("not enough params for apply command")
	}
	arg1, arg2 := i[0], i[1]

	if _, ok := h.bag[arg1]; !ok {
		return fmt.Sprintf("нет предмета в инвентаре - %s", arg1), fmt.Errorf("no item in bag: %s", arg1)
	}

	for _, a := range h.pos.actions {
		if a.inv == arg1 && a.obj == arg2 {
			h.doneActions = append(h.doneActions, a)
			return a.do(), nil
		}
	}

	return "не к чему применить", fmt.Errorf("no found action for %s %s", arg1, arg2)
}

func (h *Hero) LookAround() string {
	return h.pos.lookAround()
}

func CreateHero(p *Place) *Hero {
	return &Hero{
		pos: p,
		bag: nil,
		inv: nil,
	}
}

func CreateRoute(p ...string) []string {
	return p
}

func CreatePlaces(p ...string) map[string]*Place {
	pls := make(map[string]*Place, len(p))

	for _, v := range p {
		pls[v] = &Place{}
	}

	for k := range pls {
		switch k {
		case kitchenPlace:
			pls[k].name = kitchenPlace
			pls[k].inv = nil
			pls[k].actions = nil
			pls[k].nextPlace = map[string]struct{}{
				hallPlace: {},
			}
			pls[k].lookAround = func() string {
				if Player.bag != nil {
					return fmt.Sprintf("ты находишься на кухне, на столе: чай, надо идти в универ. можно пройти - %s", hallPlace)
				}
				return fmt.Sprintf("ты находишься на кухне, на столе: чай, надо собрать рюкзак и идти в универ. можно пройти - %s", hallPlace)
			}
			pls[k].getInfo = func() string {
				return fmt.Sprintf("кухня, ничего интересного. можно пройти - %s", hallPlace)
			}
		case hallPlace:
			pls[k].name = hallPlace
			pls[k].inv = nil
			pls[k].actions = nil
			pls[k].nextPlace = map[string]struct{}{
				kitchenPlace: {},
				roomPlace:    {},
				streetPlace:  {},
			}
			pls[k].lookAround = func() string {
				return fmt.Sprintf("ничего интересного. можно пройти - %s, %s, %s", kitchenPlace, roomPlace, streetPlace)
			}
			pls[k].getInfo = func() string {
				return fmt.Sprintf("ничего интересного. можно пройти - %s, %s, %s", kitchenPlace, roomPlace, streetPlace)
			}
			pls[k].actions = []Action{
				{
					inv:  keysInventory,
					obj:  doorObject,
					done: true,
					do: func() string {
						return "дверь открыта"
					},
				},
			}
		case roomPlace:
			pls[k].name = roomPlace
			pls[k].inv = map[string]struct{}{
				bagInventory:   {},
				keysInventory:  {},
				notesInventory: {},
			}
			pls[k].actions = nil
			pls[k].nextPlace = map[string]struct{}{
				hallPlace: {},
			}
			pls[k].lookAround = func() string {
				room := PlacePlan[roomPlace]
				_, ok1 := room.inv[keysInventory]
				_, ok2 := room.inv[notesInventory]

				switch true {
				case Player.bag == nil:
					return fmt.Sprintf("на столе: ключи, конспекты, на стуле: рюкзак. можно пройти - %s", hallPlace)
				case ok1 && ok2 && Player.bag != nil:
					return fmt.Sprintf("на столе: ключи, конспекты. можно пройти - %s", hallPlace)
				case ok1 && Player.bag != nil:
					return fmt.Sprintf("на столе: ключи. можно пройти - %s", hallPlace)
				case ok2 && Player.bag != nil:
					return fmt.Sprintf("на столе: конспекты. можно пройти - %s", hallPlace)
				case !ok1 && !ok2 && Player.bag != nil:
					return fmt.Sprintf("пустая комната. можно пройти - %s", hallPlace)
				default:
					return fmt.Sprintf("на столе: ключи, конспекты. можно пройти - %s", hallPlace)
				}
			}
			pls[k].getInfo = func() string {
				return fmt.Sprintf("ты в своей комнате. можно пройти - %s", hallPlace)
			}
		case streetPlace:
			pls[k].name = streetPlace
			pls[k].inv = nil
			pls[k].actions = nil
			pls[k].getInfo = func() string {
				return fmt.Sprint("на улице весна. можно пройти - домой")
			}
			pls[k].checkEnter = func() (string, error) {
				if len(Player.doneActions) == 0 {
					return "дверь закрыта", fmt.Errorf("door is closed")
				}
				return "на улице весна. можно пройти - домой", nil
			}
		}
	}

	return pls
}

var (
	Route     []string
	Player    *Hero
	PlacePlan map[string]*Place
)

func initGame() {
	// main route for a hero
	Route = CreateRoute(kitchenPlace, hallPlace, roomPlace, streetPlace)

	// init rooms with queue
	PlacePlan = CreatePlaces(Route...)

	if PlacePlan == nil {
		panic("place plan is empty")
	}

	// create player + add first start position
	Player = CreateHero(PlacePlan[kitchenPlace])
}

func handleCommand(command string) string {
	res, err := ExecuteCommand(strings.Split(command, " "))
	if err != nil {
		slog.Error(">" + err.Error() + "<")
		// return err.Error()
	}
	return res
}

func ExecuteCommand(c []string) (string, error) {
	if len(c) == 0 {
		return "", fmt.Errorf("no command provided")
	}
	var (
		res string
		err error
	)

	switch c[0] {
	case lookAroundAction:
		return Player.LookAround(), nil
	case goToAction:
		res, err = Player.GoTo(c[1:])
		if err != nil {
			return res, err
		}
		return Player.pos.getInfo(), nil
	case putOnAction:
		res, err = Player.PutOn(c[1:])
		if err != nil {
			return "", err
		}
		return res, nil
	case takeAction:
		res, err = Player.Take(c[1:])
		if err != nil {
			return res, err
		}
		return res, nil
	case applyAction:
		res, err = Player.Apply(c[1:])
		if err != nil {
			return res, err
		}
		return res, nil
	}

	return "неизвестная команда", fmt.Errorf("not implemented command: %s", c[0])
}
