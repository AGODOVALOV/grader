package main

import (
	"encoding/json"
	"encoding/xml"
	"fmt"
	"io/ioutil"
	"log"
	"net/http"
	"os"
	"sort"
	"strconv"
	"strings"
)

const FilePath = "dataset.xml"

// структура XML
type xmlStruct struct {
	ID        string `xml:"id"`
	Age       string `xml:"age"`
	FirstName string `xml:"first_name"`
	LastName  string `xml:"last_name"`
	Gender    string `xml:"gender"`
	About     string `xml:"about"`
}

type xmlRoot struct {
	Row []xmlStruct `xml:"row"`
}

type MainDataBase []xmlStruct

var MDB MainDataBase

func GetXMLdata(path string) (MainDataBase, error) {
	var err error
	file, err := os.Open(FilePath)
	if err != nil {
		log.Println(err) //обработка ошибки чтения файла
		return nil, err
	}

	defer func(file *os.File) {
		err := file.Close()
		if err != nil {
			log.Println(err)
		}
	}(file)

	fileContents, err := ioutil.ReadAll(file)
	if err != nil {
		log.Println(err)
		return nil, err
	}

	dataContent := new(xmlRoot)

	err = xml.Unmarshal(fileContents, &dataContent)
	if err != nil {
		log.Println(err)
		return nil, err
	}
	return dataContent.Row, err
}

func mapValidDataDB(val xmlStruct) (user User, err error) {
	//var user User
	//var err error
	user.Id, err = strconv.Atoi(val.ID)
	if err != nil {
		return user, fmt.Errorf("XML data is incorrect field Id value : %v", val.ID)
	}
	user.Name = val.FirstName + val.LastName
	user.Age, err = strconv.Atoi(val.Age)
	if err != nil {
		return user, fmt.Errorf("XML data is incorrect field Age value : %v", val.Age)
	}
	user.About = val.About
	user.Gender = val.Gender
	return
}

func getDataDB(searchRestrict *SearchRequest, mdb *MainDataBase) (searchResp SearchResponse, err error) {

	for _, val := range *mdb {
		if strings.Contains(val.About+val.FirstName+val.LastName, searchRestrict.Query) ||
			searchRestrict.Query == "" {
			//добавил обработку ошибки валидации данных
			validData, errValid := mapValidDataDB(val)
			if errValid != nil {
				err = errValid
				return
			}
			searchResp.Users = append(searchResp.Users, validData)
			//searchResp.Users = append(searchResp.Users, mapValidDataDB(val))
		}
	}

	//верхняя проверка на то что хоть какието записи нашлись
	if len(searchResp.Users) == 0 {
		//инициировать ошибку!!!
		return
	}

	//сортировка
	switch searchRestrict.OrderField {
	case "id":
		{
			//OrderByAsc  = -1 //по восходящей
			//OrderByDesc = 1 // по убыванию
			sortById(searchRestrict, searchResp)
		}
	case "age":
		{
			sortByAge(searchRestrict, searchResp)
		}
	case "name", "":
		{
			sortByName(searchRestrict, searchResp)
		}
	}

	//offset - начиная с какой записи вернуть (сколько пропустить с начала) - нужно для огранизации постраничной навигации
	if searchRestrict.Offset > 0 && len(searchResp.Users) > searchRestrict.Offset {
		searchResp.Users = searchResp.Users[searchRestrict.Offset:]
	}

	//limit - сколько записей вернуть
	if searchRestrict.Limit > 0 &&
		len(searchResp.Users) > searchRestrict.Limit {
		searchResp.Users = searchResp.Users[0:searchRestrict.Limit]
	}

	return searchResp, err
}

func sortById(searchRestrict *SearchRequest, searchResp SearchResponse) {
	sort.Slice(searchResp.Users,
		func(i, j int) bool {
			if searchRestrict.OrderBy == OrderByAsc {
				return searchResp.Users[i].Id < searchResp.Users[j].Id
			}
			if searchRestrict.OrderBy == OrderByDesc {
				return searchResp.Users[i].Id > searchResp.Users[j].Id
			}
			return true
		})
}

func sortByAge(searchRestrict *SearchRequest, searchResp SearchResponse) {
	sort.Slice(searchResp.Users,
		func(i, j int) bool {
			if searchRestrict.OrderBy == OrderByAsc {
				return searchResp.Users[i].Age < searchResp.Users[j].Age
			}
			if searchRestrict.OrderBy == OrderByDesc {
				return searchResp.Users[i].Age > searchResp.Users[j].Age
			}
			return true
		})
}

func sortByName(searchRestrict *SearchRequest, searchResp SearchResponse) {
	sort.Slice(searchResp.Users,
		func(i, j int) bool {
			if searchRestrict.OrderBy == OrderByAsc {
				return searchResp.Users[i].Name < searchResp.Users[j].Name
			}
			if searchRestrict.OrderBy == OrderByDesc {
				return searchResp.Users[i].Name > searchResp.Users[j].Name
			}
			return true
		})
}

func SearchServer(w http.ResponseWriter, r *http.Request) {

	setStatusIntSrvError := func(e error) {
		w.WriteHeader(http.StatusInternalServerError)
		w.Write([]byte(e.Error()))
		return
	}
	searchReqParam := mapGetParams(r)

	data, err := getDataDB(&searchReqParam, &MDB)
	if err != nil {
		setStatusIntSrvError(err)
	}

	respJson, err := json.Marshal(data.Users)
	if err != nil {
		setStatusIntSrvError(err)
	}

	//ответ на GET запрос
	_, err = w.Write(respJson)
	if err != nil {
		setStatusIntSrvError(err)
	}
}

func mapGetParams(r *http.Request) SearchRequest {
	var err error
	var searchReqParam SearchRequest
	searchReqParam.Query = r.FormValue("query")
	searchReqParam.OrderBy, err = strconv.Atoi(r.FormValue("order_by"))
	if err != nil {
		searchReqParam.OrderBy = OrderByAsIs
	}
	searchReqParam.OrderField = r.FormValue("order_field")
	searchReqParam.Offset, err = strconv.Atoi(r.FormValue("offset"))
	if err != nil {
		searchReqParam.Offset = 0
	}
	searchReqParam.Limit, err = strconv.Atoi(r.FormValue("limit"))
	if err != nil {
		searchReqParam.Limit = 0
	}
	return searchReqParam
}

func startServer() {
	http.HandleFunc("/myserver/", SearchServer)
	fmt.Println("starting server at :8080")
	http.ListenAndServe(":8080", nil)
}

func main() {
	var err error
	MDB, err = GetXMLdata(FilePath)
	if err != nil {
		log.Fatal("Server can not be started")
	}
	startServer()
}
